@page
@model RealEstateListingPlatform.Pages.Admin.UsersModel

@{
    ViewData["Title"] = "Quản trị - Người dùng";
}

<header class="admin-header">
    <div>
        <h2>Người dùng</h2>
        <p class="admin-muted mb-0">Tình trạng các tài khoản hoạt động gần đây.</p>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-3">
        <span class="admin-badge success">@Model.ViewModel.Users.Count Đang hoạt động</span>
        <button class="btn btn-dark px-4">Mời người dùng</button>
    </div>
</header>

<section class="admin-section">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h3>Tổng quan tài khoản</h3>
            <div class="admin-section-subtitle">Xem xét các tài khoản và trạng thái hiện tại</div>
        </div>
        <span class="admin-badge success">@Model.ViewModel.Users.Count Đang hoạt động</span>
    </div>

    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle mb-0 admin-table">
            <thead class="bg-light">
                <tr>
                    <th class="text-uppercase small text-muted">Người dùng</th>
                    <th class="text-uppercase small text-muted">Vai trò</th>
                    <th class="text-uppercase small text-muted">Gói</th>
                    <th class="text-uppercase small text-muted">Trạng thái</th>
                    <th class="text-uppercase small text-muted">Hoạt động cuối</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.ViewModel.Users)
                {
                    var tone = user.Status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "success" : "danger";
                    var initial = string.IsNullOrWhiteSpace(user.Name) ? "?" : user.Name.Trim().Substring(0, 1).ToUpperInvariant();
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="admin-avatar">@initial</div>
                                <div>
                                    <div class="fw-semibold">@user.Name</div>
                                    <div class="admin-muted small">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="admin-muted">@user.Role</td>
                        <td class="admin-muted">@user.Plan</td>
                        <td><span class="admin-badge @tone">@user.Status</span></td>
                        <td class="admin-muted">@user.LastActive</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
