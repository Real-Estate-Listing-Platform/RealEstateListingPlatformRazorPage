@model RealEstateListingPlatform.Models.ListingComparisonViewModel

<div class="row g-4">
    @if (Model.IsUpdate)
    {
        <!-- Original Version (Before Edit) -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light border-0">
                    <h6 class="fw-bold mb-0 text-muted">
                        <i class="bi bi-clock-history me-2"></i>Bản gốc
                    </h6>
                </div>
                <div class="card-body">
                    @if (Model.Original != null)
                    {
                        @await Html.PartialAsync("_ListingDataDisplay", Model.Original, new ViewDataDictionary(ViewData) { { "ShowChanges", false } })
                    }
                </div>
            </div>
        </div>

        <!-- Current Version (After Edit) -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white border-0">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Bản chỉnh sửa
                    </h6>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_ListingDataDisplay", Model.Current, new ViewDataDictionary(ViewData) 
                    { 
                        { "ShowChanges", true },
                        { "Comparison", Model }
                    })
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- New Listing (No Comparison) -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white border-0">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Bài đăng mới
                    </h6>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_ListingDataDisplay", Model.Current, new ViewDataDictionary(ViewData) { { "ShowChanges", false } })
                </div>
            </div>
        </div>
    }
</div>

@{
    var changedCount = 0;
    if (Model.IsUpdate && Model.Original != null)
    {
        var fields = new[] { "Tên bài đăng", "Mô tả", "Loại giao dịch", "Loại bất động sản", "Giá", 
                           "Địa chỉ", "Diện tích", "Số phòng ngủ", "Số phòng tắm", "Số tầng", 
                           "Trạng thái pháp lý", "Tình trạng nội thất", "Hướng", "Ảnh" };
        changedCount = fields.Count(f => Model.HasChanged(f));
    }
}

@if (Model.IsUpdate)
{
    <div class="alert alert-info mt-3 border-0">
        <i class="bi bi-info-circle me-2"></i>
        <strong>@changedCount mục đã được chỉnh sửa</strong> trong bản cập nhật này. Các mục thay đổi đã được đánh dấu ở trên.
    </div>
}
