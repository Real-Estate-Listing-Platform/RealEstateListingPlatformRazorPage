<!DOCTYPE html>
<html lang="vi">
@await RenderSectionAsync("Styles", required: false)
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nền Tảng Bất Động Sản</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstateListingPlatform.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar fixed-top navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index">
                    <img src="~/images/logo.png" alt="Estately Logo" height="40" class="d-inline-block align-top" />
                </a>   
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">                      
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Listings/BrowseListings" asp-route-type="Sell">Mua bán</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Listings/BrowseListings" asp-route-type="Rent">Cho thuê</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Seeker"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Seeker/InterestedListings">
                                    Quan tâm của tôi
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-modern bg-light text-dark pt-5 pb-4 border-top">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <a class="navbar-brand mb-3 d-inline-block" asp-page="/Index">
                        <img src="~/images/logo.png" alt="Estately Logo" height="50" class="d-inline-block" />
                    </a>
                    <p class="text-muted-custom small">
                        Nền tảng giao dịch bất động sản uy tín hàng đầu, giúp bạn tìm được ngôi nhà mơ ước chỉ với vài cú nhấp chuột.
                    </p>
                    <div class="social-links mt-3">
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle me-2"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold mb-4">Liên kết nhanh</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-page="/Index" class="text-muted-custom">Trang chủ</a></li>
                        <li><a href="#" class="text-muted-custom">Tất cả tin đăng</a></li>
                        <li><a href="#" class="text-muted-custom">Về chúng tôi</a></li>
                        <li><a asp-page="/Privacy" class="text-muted-custom">Chính sách bảo mật</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-4">Liên hệ</h6>
                    <ul class="list-unstyled footer-contact">
                        <li class="mb-2 text-muted-custom small">
                            <i class="bi bi-geo-alt text-primary me-2"></i> 123 Quận 1, TP. Hồ Chí Minh
                        </li>
                        <li class="mb-2 text-muted-custom small">
                            <i class="bi bi-telephone text-primary me-2"></i> +84 123 456 789
                        </li>
                        <li class="text-muted-custom small">
                            <i class="bi bi-envelope text-primary me-2"></i> contact@estately.vn
                        </li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-4">Bản tin</h6>
                    <p class="text-muted-custom small">Đăng ký để nhận thông tin mới nhất về các dự án.</p>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control form-control-sm border-secondary text-dark" placeholder="Địa chỉ email">
                        <button class="btn btn-primary btn-sm" type="button">Đăng ký</button>
                    </div>
                </div>
            </div>

            <hr class="mt-4 border-secondary opacity-25">

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted-custom small mb-0">&copy; 2026 - Estately. Mọi quyền được bảo lưu.</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- AI Chatbot Bubble -->
    <div class="chatbot-bubble" id="chatbotBubble" onclick="toggleChatbotWidget()" title="AI Property Assistant">
        <i class="bi bi-robot" id="chatbotBubbleIcon"></i>
        <span class="chatbot-bubble-badge" id="chatbotBadge" style="display:none">1</span>
    </div>

    <!-- Chatbot Mini Widget -->
    <div class="chatbot-widget" id="chatbotWidget" style="display:none">
        <div class="chatbot-widget-header">
            <div class="d-flex align-items-center gap-2">
                <div class="chatbot-widget-avatar"><i class="bi bi-robot"></i></div>
                <div>
                    <div class="fw-semibold" style="font-size:0.9rem">AI Property Assistant</div>
                    <div style="font-size:0.75rem;color:#a3e635">● Online</div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="/Chatbot" class="chatbot-expand-btn" title="Mở rộng"><i class="bi bi-arrows-fullscreen"></i></a>
                <button class="chatbot-close-btn" onclick="toggleChatbotWidget()"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>
        <div class="chatbot-widget-messages" id="widgetMessages">
            <div class="widget-message bot">
                <i class="bi bi-robot widget-avatar"></i>
                <div class="widget-bubble">Xin chào! Tôi có thể giúp bạn tìm bất động sản. Bạn đang tìm kiếm gì? 🏠</div>
            </div>
        </div>
        <div class="chatbot-widget-input">
            <input type="text" id="widgetInput" placeholder="Nhập tin nhắn..." onkeydown="handleWidgetKeyDown(event)">
            <button onclick="sendWidgetMessage()"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>

    <style>
        .chatbot-bubble {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 4px 20px rgba(102,126,234,0.45);
            z-index: 1050;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .chatbot-bubble:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(102,126,234,0.55); }
        .chatbot-bubble-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            width: 20px;
            height: 20px;
            background: #ef4444;
            border-radius: 50%;
            font-size: 0.7rem;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }
        .chatbot-widget {
            position: fixed;
            bottom: 96px;
            right: 28px;
            width: 360px;
            height: 480px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.18);
            z-index: 1049;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: slideUp 0.25s ease;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .chatbot-widget-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 14px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            flex-shrink: 0;
        }
        .chatbot-widget-avatar {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }
        .chatbot-expand-btn, .chatbot-close-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 30px;
            height: 30px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.85rem;
            text-decoration: none;
            transition: background 0.2s;
        }
        .chatbot-expand-btn:hover, .chatbot-close-btn:hover { background: rgba(255,255,255,0.35); color: white; }
        .chatbot-widget-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .widget-message {
            display: flex;
            gap: 8px;
            align-items: flex-start;
        }
        .widget-message.user { flex-direction: row-reverse; }
        .widget-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            flex-shrink: 0;
        }
        .widget-bubble {
            max-width: 80%;
            padding: 9px 13px;
            border-radius: 14px;
            font-size: 0.85rem;
            line-height: 1.5;
        }
        .widget-message.bot .widget-bubble { background: #f3f4f6; color: #1f2937; border-top-left-radius: 4px; }
        .widget-message.user .widget-bubble { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-top-right-radius: 4px; }
        .chatbot-widget-input {
            padding: 12px 14px;
            border-top: 1px solid #e9ecef;
            display: flex;
            gap: 8px;
            align-items: center;
            flex-shrink: 0;
        }
        .chatbot-widget-input input {
            flex: 1;
            border: 1.5px solid #e9ecef;
            border-radius: 10px;
            padding: 8px 12px;
            font-size: 0.85rem;
            outline: none;
        }
        .chatbot-widget-input input:focus { border-color: #7c3aed; }
        .chatbot-widget-input button {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.85rem;
        }
        @@media (max-width: 480px) {
            .chatbot-widget { width: calc(100vw - 32px); right: 16px; bottom: 88px; }
        }
    </style>

    <script>
        let widgetHistory = [];
        let widgetLoading = false;

        function toggleChatbotWidget() {
            const widget = document.getElementById('chatbotWidget');
            const badge = document.getElementById('chatbotBadge');
            const isHidden = widget.style.display === 'none';
            widget.style.display = isHidden ? 'flex' : 'none';
            if (isHidden) badge.style.display = 'none';
        }

        function handleWidgetKeyDown(e) {
            if (e.key === 'Enter') sendWidgetMessage();
        }

        async function sendWidgetMessage() {
            const input = document.getElementById('widgetInput');
            const msg = input.value.trim();
            if (!msg || widgetLoading) return;

            appendWidgetMessage('user', msg);
            widgetHistory.push({ role: 'user', content: msg });
            input.value = '';

            const typingEl = appendWidgetTyping();
            widgetLoading = true;

            try {
                const res = await fetch('/api/Chatbot/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg, history: widgetHistory.slice(-6) })
                });
                const data = await res.json();
                typingEl.remove();
                const reply = data.success ? data.message : 'Xin lỗi, đã có lỗi xảy ra.';
                appendWidgetMessage('bot', reply);
                widgetHistory.push({ role: 'model', content: reply });
            } catch {
                typingEl.remove();
                appendWidgetMessage('bot', 'Không thể kết nối. Vui lòng thử lại.');
            } finally {
                widgetLoading = false;
            }
        }

        function appendWidgetMessage(role, text) {
            const container = document.getElementById('widgetMessages');
            const isBot = role === 'bot';
            const div = document.createElement('div');
            div.className = `widget-message ${isBot ? 'bot' : 'user'}`;
            const plain = text.replace(/\*\*(.*?)\*\*/g, '$1').replace(/\*(.*?)\*/g, '$1').replace(/\n/g, ' ');
            div.innerHTML = `
                <div class="widget-avatar">${isBot ? '<i class="bi bi-robot"></i>' : '<i class="bi bi-person-fill"></i>'}</div>
                <div class="widget-bubble">${plain}</div>`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        function appendWidgetTyping() {
            const container = document.getElementById('widgetMessages');
            const div = document.createElement('div');
            div.className = 'widget-message bot';
            div.innerHTML = `
                <div class="widget-avatar"><i class="bi bi-robot"></i></div>
                <div class="widget-bubble" style="padding:10px 14px">
                    <span style="display:inline-flex;gap:4px">
                        <span style="width:7px;height:7px;background:#9ca3af;border-radius:50%;animation:typing 1.2s infinite"></span>
                        <span style="width:7px;height:7px;background:#9ca3af;border-radius:50%;animation:typing 1.2s infinite 0.2s"></span>
                        <span style="width:7px;height:7px;background:#9ca3af;border-radius:50%;animation:typing 1.2s infinite 0.4s"></span>
                    </span>
                </div>`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
            return div;
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    main {
        flex: 1 0 auto;
    }

    .navbar-nav .nav-link {
        position: relative;
        transition: color 0.3s ease;
        font-weight: 500;
    }

        .navbar-nav .nav-link:hover {
            color: #0d6efd !important; 
        }
        .navbar-nav .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: #0d6efd;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .navbar-nav .nav-link:hover::after {
            width: 80%;
        }

    .footer-modern {
        background-color: #f8f9fa !important; 
        border-top: 1px solid #dee2e6 !important;
    }

        .footer-modern a {
            color: #6c757d;
            transition: color 0.3s;
        }

            .footer-modern a:hover {
                color: #0d6efd !important;
            }

        .footer-modern .form-control {
            border-color: #ced4da;
            font-size: 0.9rem;
        }
</style>