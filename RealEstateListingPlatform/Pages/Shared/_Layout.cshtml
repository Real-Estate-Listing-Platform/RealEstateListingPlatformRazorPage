<!DOCTYPE html>
<html lang="vi">
@await RenderSectionAsync("Styles", required: false)
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nền Tảng Bất Động Sản</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RealEstateListingPlatform.styles.css" asp-append-version="true" />
</head>


<body>

    <!-- Chatbot -->
    <button class="chatbot-toggler" id="chatbot-toggler">
        <i class="bi bi-chat-dots-fill"></i>
        <i class="bi bi-x-lg"></i>
    </button>

    <div class="chatbot-window" id="chatbot-window">
        <header>
            <h2>Tư vấn Bất Động Sản</h2>
            <span class="close-btn" id="close-chatbot"><i class="bi bi-x"></i></span>
        </header>
        <ul class="chatbox" id="chatbox">
            <li class="chat incoming">
                <span class="material-icons"><i class="bi bi-robot"></i></span>
                <p>Xin chào! Mình là trợ lý ảo. Bạn đang quan tâm đến khu vực hoặc phân khúc nhà đất nào?</p>
            </li>
        </ul>
        <div class="chat-input-wrapper">
            <textarea id="chat-input" placeholder="Nhập tin nhắn..." required></textarea>
            <button id="send-btn" class="btn"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>

    <!-- Header -->
    <header>
        <nav class="navbar fixed-top navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-page="/Index">
                    <img src="~/images/logo.png" alt="Estately Logo" height="40" class="d-inline-block align-top" />
                </a>   
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">                      
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Listings/BrowseListings" asp-route-type="Sell">Mua bán</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Listings/BrowseListings" asp-route-type="Rent">Cho thuê</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Seeker"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Seeker/InterestedListings">
                                    Quan tâm của tôi
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-modern bg-light text-dark pt-5 pb-4 border-top">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <a class="navbar-brand mb-3 d-inline-block" asp-page="/Index">
                        <img src="~/images/logo.png" alt="Estately Logo" height="50" class="d-inline-block" />
                    </a>
                    <p class="text-muted-custom small">
                        Nền tảng giao dịch bất động sản uy tín hàng đầu, giúp bạn tìm được ngôi nhà mơ ước chỉ với vài cú nhấp chuột.
                    </p>
                    <div class="social-links mt-3">
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle me-2"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold mb-4">Liên kết nhanh</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-page="/Index" class="text-muted-custom">Trang chủ</a></li>
                        <li><a href="#" class="text-muted-custom">Tất cả tin đăng</a></li>
                        <li><a href="#" class="text-muted-custom">Về chúng tôi</a></li>
                        <li><a asp-page="/Privacy" class="text-muted-custom">Chính sách bảo mật</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-4">Liên hệ</h6>
                    <ul class="list-unstyled footer-contact">
                        <li class="mb-2 text-muted-custom small">
                            <i class="bi bi-geo-alt text-primary me-2"></i> 123 Quận 1, TP. Hồ Chí Minh
                        </li>
                        <li class="mb-2 text-muted-custom small">
                            <i class="bi bi-telephone text-primary me-2"></i> +84 123 456 789
                        </li>
                        <li class="text-muted-custom small">
                            <i class="bi bi-envelope text-primary me-2"></i> contact@estately.vn
                        </li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-4">Bản tin</h6>
                    <p class="text-muted-custom small">Đăng ký để nhận thông tin mới nhất về các dự án.</p>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control form-control-sm border-secondary text-dark" placeholder="Địa chỉ email">
                        <button class="btn btn-primary btn-sm" type="button">Đăng ký</button>
                    </div>
                </div>
            </div>

            <hr class="mt-4 border-secondary opacity-25">

            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <p class="text-muted-custom small mb-0">&copy; 2026 - Estately. Mọi quyền được bảo lưu.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    main {
        flex: 1 0 auto;
    }

    .navbar-nav .nav-link {
        position: relative;
        transition: color 0.3s ease;
        font-weight: 500;
    }

        .navbar-nav .nav-link:hover {
            color: #0d6efd !important; 
        }
        .navbar-nav .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 50%;
            background-color: #0d6efd;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .navbar-nav .nav-link:hover::after {
            width: 80%;
        }

    .footer-modern {
        background-color: #f8f9fa !important; 
        border-top: 1px solid #dee2e6 !important;
    }

        .footer-modern a {
            color: #6c757d;
            transition: color 0.3s;
        }

            .footer-modern a:hover {
                color: #0d6efd !important;
            }

        .footer-modern .form-control {
            border-color: #ced4da;
            font-size: 0.9rem;
        }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const chatbotToggler = document.querySelector("#chatbot-toggler");
        const closeBtn = document.querySelector("#close-chatbot");
        const chatbox = document.querySelector("#chatbox");
        const chatInput = document.querySelector("#chat-input");
        const sendChatBtn = document.querySelector("#send-btn");

        // Thay đổi trạng thái mở/đóng chatbot
        chatbotToggler.addEventListener("click", () => document.body.classList.toggle("show-chatbot"));
        closeBtn.addEventListener("click", () => document.body.classList.remove("show-chatbot"));

        const createChatLi = (message, className) => {
            // Tạo thẻ <li> chứa tin nhắn
            const chatLi = document.createElement("li");
            chatLi.classList.add("chat", className);
            
            // Nếu là tin nhắn nhận về (incoming), thêm icon robot
            let chatContent = className === "outgoing" 
                ? `<p></p>` 
                : `<span class="material-icons"><i class="bi bi-robot"></i></span><p></p>`;
                
            chatLi.innerHTML = chatContent;
            chatLi.querySelector("p").textContent = message;
            return chatLi;
        }

        const handleChat = () => {
            const userMessage = chatInput.value.trim();
            if (!userMessage) return;

            // Xóa nội dung input và reset chiều cao textarea (nếu có auto-resize)
            chatInput.value = "";

            // 1. Hiển thị tin nhắn của người dùng
            chatbox.appendChild(createChatLi(userMessage, "outgoing"));
            chatbox.scrollTo(0, chatbox.scrollHeight);

            // 2. Hiển thị tin nhắn đang chờ (typing...)
            setTimeout(() => {
                const incomingChatLi = createChatLi("Đang nhập...", "incoming");
                chatbox.appendChild(incomingChatLi);
                chatbox.scrollTo(0, chatbox.scrollHeight);

                // 3. Ở BƯỚC NÀY: Dành cho việc gọi API backend (ví dụ: SignalR, OpenAI API, hoặc ChatGPT)
                generateResponse(incomingChatLi); 
            }, 600);
        }

        // Xử lý phản hồi ảo (Mô phỏng hệ thống tự động trả lời)
        const generateResponse = (chatElement) => {
            const messageElement = chatElement.querySelector("p");
            
            // Đoạn này dùng setTimeout để mô phỏng độ trễ khi gọi mạng
            setTimeout(() => {
                messageElement.textContent = "Cảm ơn bạn đã liên hệ! Hiện tại trợ lý đang bận xử lý dữ liệu. Xin vui lòng để lại số điện thoại hoặc email liên hệ để chuyên viên tư vấn trực tiếp cho bạn.";
                chatbox.scrollTo(0, chatbox.scrollHeight);
            }, 1500);
            
            // === Ví dụ nếu gọi API thật (Sử dụng $.ajax hoặc fetch) ===
            // fetch('/api/Chatbot/SendMessage', {
            //     method: 'POST',
            //     headers: { 'Content-Type': 'application/json' },
            //     body: JSON.stringify({ message: userMessage })
            // }).then(res => res.json()).then(data => {
            //     messageElement.textContent = data.reply;
            // }).catch(() => {
            //     messageElement.textContent = "Đã xảy ra lỗi, vui lòng thử lại.";
            // });
        };

        // Cho phép gửi tin nhắn khi bấm nút "Send" hoặc phím Enter
        sendChatBtn.addEventListener("click", handleChat);
        chatInput.addEventListener("keydown", (e) => {
            if (e.key === "Enter" && !e.shiftKey && window.innerWidth > 800) {
                e.preventDefault();
                handleChat();
            }
        });
    });
</script>