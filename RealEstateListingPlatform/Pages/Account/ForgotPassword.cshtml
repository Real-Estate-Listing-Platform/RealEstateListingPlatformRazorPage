@page
@model RealEstateListingPlatform.Pages.Account.ForgotPasswordModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="auth-toggle">
    <span class="active" style="width: 100%; display: block; text-align: center;">Quên mật khẩu</span>
</div>

<div class="text-center mb-4">
    <p>Nhập địa chỉ email của bạn để nhận mã xác thực.</p>
</div>

<form method="post" class="auth-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="mb-3">
        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Địa chỉ email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-auth-primary">Gửi mã OTP</button>
    
    <div class="mt-3 text-center">
        <a asp-page="./Login" class="text-decoration-none text-muted small">Quay lại đăng nhập</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
