@page
@model RealEstateListingPlatform.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_AuthLayout";
}

<div class="auth-toggle">
    <a asp-page="./Login" class="js-auth-switch">Đăng nhập</a>
    <a href="#" class="active">Đăng ký</a>
</div>

<form id="registerForm" method="post" class="auth-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="mb-2">
        <input asp-for="Input.FullName" class="form-control" autocomplete="name" aria-required="true" placeholder="Họ và tên" />
        <span asp-validation-for="Input.FullName" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Địa chỉ email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    
     <div class="mb-2">
        <input asp-for="Input.PhoneNumber" class="form-control" autocomplete="tel" aria-required="true" placeholder="Số điện thoại" />
        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
    </div>

    <div class="mb-2 position-relative">
        <input asp-for="Input.Password" class="form-control password-input" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu" />
        <span class="password-toggle-icon"><i class="bi bi-eye"></i></span>
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <div class="password-requirements mb-2">
        <p class="requirements-title">Yêu cầu mật khẩu:</p>
        <ul class="requirements-list">
            <li id="req-length" class="requirement-item"><span class="bullet">●</span> Tối thiểu 8 ký tự</li>
            <li id="req-uppercase" class="requirement-item"><span class="bullet">●</span> 1 chữ hoa (A-Z)</li>
            <li id="req-number" class="requirement-item"><span class="bullet">●</span> 1 chữ số (0-9)</li>
            <li id="req-special" class="requirement-item"><span class="bullet">●</span> 1 ký tự đặc biệt (!@@#$%)</li>
        </ul>
    </div>
    
    <div class="mb-3">
        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu" />
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
    </div>

    <button id="registerSubmit" type="submit" class="btn btn-auth-primary">Tạo tài khoản</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Password Toggle
            $('.password-toggle-icon').click(function() {
                var input = $(this).siblings('input');
                var icon = $(this).find('i');
                
                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('bi-eye').addClass('bi-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('bi-eye-slash').addClass('bi-eye');
                }
            });

            // Real-time Password Validation
            $('.password-input').on('input', function() {
                var password = $(this).val();
                
                // Min 8 chars
                if (password.length >= 8) {
                    $('#req-length').addClass('valid');
                } else {
                    $('#req-length').removeClass('valid');
                }

                // 1 Uppercase
                if (/[A-Z]/.test(password)) {
                    $('#req-uppercase').addClass('valid');
                } else {
                    $('#req-uppercase').removeClass('valid');
                }

                // 1 Number
                if (/[0-9]/.test(password)) {
                    $('#req-number').addClass('valid');
                } else {
                    $('#req-number').removeClass('valid');
                }

                // 1 Special char
                if (/[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) {
                    $('#req-special').addClass('valid');
                } else {
                    $('#req-special').removeClass('valid');
                }
            });
        });
    </script>
}
