@page
@model RealEstateListingPlatform.Pages.Lister.ValuationModel

@{
    ViewData["Title"] = "Định giá bất động sản";
    Layout = "_ListerLayout";
}

<div class="valuation-page">

    <!-- Header -->
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="page-title mb-1">
                    <i class="bi bi-graph-up-arrow me-2"></i>Ước tính giá trị bất động sản
                </h1>
                <p class="text-muted mb-0">
                    Nhập thông tin cơ bản để nhận ước tính giá trị dựa trên dữ liệu tin đăng thực tế trên hệ thống.
                </p>
            </div>
            <a asp-page="/Lister/Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Quay lại
            </a>
        </div>
    </div>

    <!-- Input Form -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header valuation-card-header">
            <h5 class="mb-0 text-white">
                <i class="bi bi-ui-checks-grid me-2"></i>Thông tin tra cứu
            </h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <!-- Property Type -->
                    <div class="col-md-4">
                        <label asp-for="Input.PropertyType" class="form-label required"></label>
                        <select asp-for="Input.PropertyType" asp-items="Model.PropertyTypes" class="form-select">
                            <option value="">-- Chọn loại --</option>
                        </select>
                        <span asp-validation-for="Input.PropertyType" class="text-danger small"></span>
                    </div>

                    <!-- Transaction Type -->
                    <div class="col-md-4">
                        <label asp-for="Input.TransactionType" class="form-label required"></label>
                        <select asp-for="Input.TransactionType" asp-items="Model.TransactionTypes" class="form-select"></select>
                        <span asp-validation-for="Input.TransactionType" class="text-danger small"></span>
                    </div>

                    <!-- Area -->
                    <div class="col-md-4">
                        <label asp-for="Input.AreaSqm" class="form-label required"></label>
                        <div class="input-group">
                            <input asp-for="Input.AreaSqm" class="form-control" type="number" min="1" step="0.1" placeholder="Ví dụ: 75" />
                            <span class="input-group-text">m²</span>
                        </div>
                        <span asp-validation-for="Input.AreaSqm" class="text-danger small"></span>
                    </div>

                    <!-- City -->
                    <div class="col-md-6">
                        <label asp-for="Input.City" class="form-label required"></label>
                        <input asp-for="Input.City" class="form-control" placeholder="Ví dụ: TP. Hồ Chí Minh" />
                        <span asp-validation-for="Input.City" class="text-danger small"></span>
                    </div>

                    <!-- District -->
                    <div class="col-md-6">
                        <label asp-for="Input.District" class="form-label required"></label>
                        <input asp-for="Input.District" class="form-control" placeholder="Ví dụ: Quận 7" />
                        <span asp-validation-for="Input.District" class="text-danger small"></span>
                    </div>

                    <!-- Ward (optional) -->
                    <div class="col-md-6">
                        <label asp-for="Input.Ward" class="form-label"></label>
                        <input asp-for="Input.Ward" class="form-control" placeholder="Phường / Xã (không bắt buộc)" />
                    </div>

                    <!-- Address (optional) -->
                    <div class="col-md-6">
                        <label asp-for="Input.AddressLine" class="form-label"></label>
                        <input asp-for="Input.AddressLine" class="form-control" placeholder="Số nhà, tên đường..." />
                    </div>

                    <!-- Notes (optional) -->
                    <div class="col-12">
                        <label asp-for="Input.Notes" class="form-label"></label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="3"
                                  placeholder="Ghi chú thêm về tài sản nếu cần..."></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 flex-wrap">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-calculator me-2"></i>Ước tính giá trị
                    </button>
                    <button type="reset" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-clockwise me-2"></i>Đặt lại
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ── Estimation Result ──────────────────────────────────────── -->
    @if (Model.EstimationResult != null)
    {
        var r = Model.EstimationResult;

        @if (!r.HasData)
        {
            <!-- No data -->
            <div class="alert alert-warning d-flex align-items-center gap-2" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>
                    <strong>Chưa đủ dữ liệu:</strong> @r.MarketInsight
                </div>
            </div>
        }
        else
        {
            <!-- Fallback notice -->
            @if (r.IsFallbackToCity)
            {
                <div class="alert alert-info d-flex align-items-center gap-2 py-2" role="alert">
                    <i class="bi bi-info-circle-fill"></i>
                    <small>
                        Quận/huyện chưa có đủ mẫu (≥3), kết quả được mở rộng toàn thành phố
                        <strong>@r.City</strong>.
                    </small>
                </div>
            }

            <!-- Summary cards -->
            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-lg-3">
                    <div class="stat-card text-center h-100">
                        <div class="stat-icon text-primary"><i class="bi bi-currency-exchange"></i></div>
                        <div class="stat-label">Giá ước tính (trung bình)</div>
                        <div class="stat-value text-primary">@r.EstimatedAvgPrice?.ToString("N0") VNĐ</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="stat-card text-center h-100">
                        <div class="stat-icon text-success"><i class="bi bi-arrow-down-circle"></i></div>
                        <div class="stat-label">Giá ước tính (thấp nhất)</div>
                        <div class="stat-value text-success">@r.EstimatedMinPrice?.ToString("N0") VNĐ</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="stat-card text-center h-100">
                        <div class="stat-icon text-danger"><i class="bi bi-arrow-up-circle"></i></div>
                        <div class="stat-label">Giá ước tính (cao nhất)</div>
                        <div class="stat-value text-danger">@r.EstimatedMaxPrice?.ToString("N0") VNĐ</div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                    <div class="stat-card text-center h-100">
                        <div class="stat-icon text-secondary"><i class="bi bi-houses"></i></div>
                        <div class="stat-label">Số mẫu so sánh</div>
                        <div class="stat-value text-secondary">@r.SampleCount tin đăng</div>
                    </div>
                </div>
            </div>

            <!-- Price/m² breakdown -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0">
                        <i class="bi bi-bar-chart-line me-2 text-primary"></i>Thống kê giá / m²
                        <span class="badge bg-secondary ms-2">@r.PropertyType · @(r.TransactionType == "Sell" ? "Mua bán" : "Cho thuê")</span>
                        <span class="badge bg-light text-dark border ms-1">@(r.IsFallbackToCity ? r.City : $"{r.District}, {r.City}")</span>
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row text-center g-3">
                        <div class="col-4">
                            <div class="fw-semibold text-muted small">Thấp nhất</div>
                            <div class="fs-5 fw-bold text-success">@r.MinPricePerSqm?.ToString("N0")</div>
                            <div class="text-muted small">VNĐ/m²</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-semibold text-muted small">Trung bình</div>
                            <div class="fs-4 fw-bold text-primary">@r.AvgPricePerSqm?.ToString("N0")</div>
                            <div class="text-muted small">VNĐ/m²</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-semibold text-muted small">Cao nhất</div>
                            <div class="fs-5 fw-bold text-danger">@r.MaxPricePerSqm?.ToString("N0")</div>
                            <div class="text-muted small">VNĐ/m²</div>
                        </div>
                    </div>

                    <!-- Visual range bar -->
                    <div class="mt-3 px-2">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>@r.MinPricePerSqm?.ToString("N0") VNĐ/m²</span>
                            <span>@r.MaxPricePerSqm?.ToString("N0") VNĐ/m²</span>
                        </div>
                        @{
                            var min = r.MinPricePerSqm ?? 0;
                            var max = r.MaxPricePerSqm ?? 1;
                            var avg = r.AvgPricePerSqm ?? 0;
                            var range = max - min;
                            var avgPct = range > 0 ? (int)((avg - min) / range * 100) : 50;
                        }
                        <div class="price-range-bar">
                            <div class="price-range-fill"></div>
                            <div class="price-range-marker" style="left: @avgPct%">
                                <div class="marker-label">TB</div>
                            </div>
                        </div>
                    </div>

                    <!-- Market insight -->
                    <div class="alert alert-light border-start border-primary border-3 mt-3 mb-0 py-2">
                        <i class="bi bi-lightbulb me-2 text-primary"></i>
                        <small>@r.MarketInsight</small>
                    </div>
                </div>
            </div>

            <!-- Comparable listings table -->
            @if (r.ComparableListings.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">
                            <i class="bi bi-list-ul me-2 text-secondary"></i>Tin đăng so sánh gần đây
                        </h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tiêu đề</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-center">Diện tích</th>
                                    <th class="text-end">Giá/m²</th>
                                    <th>Vị trí</th>
                                    <th class="text-center">Ngày đăng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var comp in r.ComparableListings)
                                {
                                    <tr>
                                        <td>
                                            <a href="/Listings/PropertyDetail?id=@comp.Id"
                                               class="text-decoration-none text-dark fw-semibold"
                                               target="_blank">
                                                @comp.Title
                                            </a>
                                        </td>
                                        <td class="text-end text-primary fw-semibold">
                                            @comp.Price.ToString("N0") VNĐ
                                        </td>
                                        <td class="text-center">
                                            @(comp.AreaSqm.HasValue ? $"{comp.AreaSqm:0.##} m²" : "–")
                                        </td>
                                        <td class="text-end">
                                            @(comp.PricePerSqm.HasValue ? $"{comp.PricePerSqm:N0} VNĐ/m²" : "–")
                                        </td>
                                        <td class="text-muted small">
                                            @comp.District@(comp.District != null && comp.City != null ? ", " : "")@comp.City
                                        </td>
                                        <td class="text-center text-muted small">
                                            @comp.CreatedAt?.ToString("dd/MM/yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .valuation-page { width: 100%; }

    .valuation-card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .required::after { content: " *"; color: #dc3545; }

    /* Stat cards */
    .stat-card {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: .75rem;
        padding: 1.2rem 1rem;
    }
    .stat-icon { font-size: 1.8rem; margin-bottom: .4rem; }
    .stat-label { font-size: .75rem; color: #6c757d; margin-bottom: .25rem; }
    .stat-value { font-size: 1.1rem; font-weight: 700; }

    /* Range bar */
    .price-range-bar {
        position: relative;
        height: 8px;
        background: linear-gradient(90deg, #28a745, #ffc107, #dc3545);
        border-radius: 4px;
        margin: 0 8px;
    }
    .price-range-fill { display: none; }
    .price-range-marker {
        position: absolute;
        top: -4px;
        transform: translateX(-50%);
        width: 16px;
        height: 16px;
        background: #fff;
        border: 2.5px solid #0d6efd;
        border-radius: 50%;
    }
    .marker-label {
        position: absolute;
        top: -20px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 9px;
        font-weight: 700;
        color: #0d6efd;
        white-space: nowrap;
    }
</style>
