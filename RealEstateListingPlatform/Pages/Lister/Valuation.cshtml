@page
@model RealEstateListingPlatform.Pages.Lister.ValuationModel

@{
    ViewData["Title"] = "Yeu cau dinh gia";
    Layout = "_ListerLayout";
}

<div class="valuation-page">
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="page-title mb-1">
                    <i class="bi bi-graph-up-arrow me-2"></i>Yeu cau dinh gia bat dong san
                </h1>
                <p class="text-muted mb-0">Nhap thong tin co ban de nhan uoc tinh gia tri va du lieu thi truong.</p>
            </div>
            <a asp-page="/Lister/Dashboard" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Quay lai
            </a>
        </div>
    </div>

    @if (TempData["ValuationSuccess"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header valuation-card-header">
            <h5 class="mb-0 text-white">
                <i class="bi bi-ui-checks-grid me-2"></i>Thong tin yeu cau (RELP-54)
            </h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Input.PropertyType" class="form-label required"></label>
                        <select asp-for="Input.PropertyType" asp-items="Model.PropertyTypes" class="form-select">
                            <option value="">-- Chon loai --</option>
                        </select>
                        <span asp-validation-for="Input.PropertyType" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.AreaSqm" class="form-label required"></label>
                        <div class="input-group">
                            <input asp-for="Input.AreaSqm" class="form-control" type="number" min="1" step="0.1" placeholder="Vi du: 75" />
                            <span class="input-group-text">m2</span>
                        </div>
                        <span asp-validation-for="Input.AreaSqm" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.City" class="form-label required"></label>
                        <input asp-for="Input.City" class="form-control" placeholder="Vi du: TP. Ho Chi Minh" />
                        <span asp-validation-for="Input.City" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.District" class="form-label required"></label>
                        <input asp-for="Input.District" class="form-control" placeholder="Vi du: Quan 7" />
                        <span asp-validation-for="Input.District" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.Ward" class="form-label"></label>
                        <input asp-for="Input.Ward" class="form-control" placeholder="Vi du: Phuong Tan Hung" />
                        <span asp-validation-for="Input.Ward" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.AddressLine" class="form-label"></label>
                        <input asp-for="Input.AddressLine" class="form-control" placeholder="So nha, ten duong..." />
                        <span asp-validation-for="Input.AddressLine" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Notes" class="form-label"></label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="4" placeholder="Nhap them thong tin mo ta tai san neu can..."></textarea>
                        <span asp-validation-for="Input.Notes" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 flex-wrap">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-send me-2"></i>Gui yeu cau
                    </button>
                    <button type="reset" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-clockwise me-2"></i>Dat lai
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .valuation-page {
        max-width: 980px;
    }

    .valuation-card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .required::after {
        content: " *";
        color: #dc3545;
    }
</style>
