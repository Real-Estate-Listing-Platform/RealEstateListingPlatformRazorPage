    .package-option input[type="radio"]:checked {
        border-color: #667eea;
    }

    .package-selection-container {
        max-height: 400px;
        overflow-y: auto;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
</style>
