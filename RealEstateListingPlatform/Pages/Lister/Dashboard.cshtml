@page
@model RealEstateListingPlatform.Pages.Lister.DashboardModel
@using BLL.DTOs

@{
    ViewData["Title"] = "Tổng quan";
    Layout = "_ListerLayout";
    var stats = Model.Stats ?? new DashboardStatsDto();
}

<div class="dashboard-container">
    <!-- Page Header -->
    <div class="page-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="page-title">
                    <i class="bi bi-speedometer2 me-2"></i>Tổng quan
                </h1>
                <p class="page-subtitle text-muted">Chào mừng trở lại! Dưới đây là tình hình các tin đăng của bạn hôm nay.</p>
            </div>
            <div id="signalr-status" class="d-flex align-items-center gap-2">
                <span class="badge bg-secondary" id="connection-badge">
                    <i class="bi bi-wifi-off"></i> Đang kết nối...
                </span>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <!-- Row 1: Primary Listing Metrics -->
        <div class="col-md-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-icon">
                    <i class="bi bi-buildings"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-totalListings">@stats.TotalListings</h3>
                    <p class="stat-label">Tổng tin đăng</p>
                    <small class="text-muted">Tỷ lệ duyệt: <span id="stat-publishSuccessRate">@stats.PublishSuccessRate</span>%</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-success">
                <div class="stat-icon">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-activeListings">@stats.ActiveListings</h3>
                    <p class="stat-label">Tin đang hiển</p>
                    <small class="text-success"><i class="bi bi-arrow-up"></i> Đãxuất bản</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-icon">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-pendingReview">@stats.PendingReview</h3>
                    <p class="stat-label">Chờ duyệt</p>
                    <small class="text-warning">Đang chờ phê duyệt</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-info">
                <div class="stat-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-totalLeads">@stats.TotalLeads</h3>
                    <p class="stat-label">Tổng khách hàng</p>
                    <span class="badge bg-danger" id="stat-newLeadsBadge">@stats.NewLeads Mới</span>
                </div>
            </div>
        </div>

        <!-- Row 2: Additional Metrics -->
        <div class="col-md-3">
            <div class="stat-card stat-card-secondary">
                <div class="stat-icon">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-draftListings">@stats.DraftListings</h3>
                    <p class="stat-label">Tin nháp</p>
                    <small class="text-muted">Chưa gửi duyệt</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-danger">
                <div class="stat-icon">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-expiredListings">@stats.ExpiredListings</h3>
                    <p class="stat-label">Tin hết hạn</p>
                    @if (stats.ExpiringListingsSoon > 0)
                    {
                        <small class="text-danger"><span id="stat-expiringListingsSoon">@stats.ExpiringListingsSoon</span> sắp hết hạn</small>
                    }
                    else
                    {
                        <small class="text-muted">Không có tin sắp hết hạn</small>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-boost">
                <div class="stat-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-boostedListings">@stats.BoostedListings</h3>
                    <p class="stat-label">Tin được đẩy</p>
                    <small class="text-warning"><i class="bi bi-star-fill"></i> Nổi bật</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-card-conversion">
                <div class="stat-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number" id="stat-conversionRate">@stats.ConversionRate%</h3>
                    <p class="stat-label">Tỷ lệ chuyển đổi</p>
                    <small class="text-muted"><span id="stat-closedLeads">@stats.ClosedLeads</span> KH đã chốt</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Performance Overview and Top Listings -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="dashboard-card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="bi bi-bar-chart me-2"></i>Tổng quan hiệu suất
                    </h5>
                    <small class="text-muted">7 ngày gần nhất</small>
                </div>
                <div class="card-body">
                    <canvas id="performanceChart" height="80"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dashboard-card">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="bi bi-people-fill me-2"></i>Thống kê khách hàng
                    </h5>
                </div>
                <div class="card-body">
                    <div class="revenue-item mb-4">
                        <p class="text-muted mb-1">Tổng khách hàng</p>
                        <h3 class="text-primary mb-2" id="panel-totalLeads">@stats.TotalLeads</h3>
                        <div class="progress mb-2" style="height: 8px;">
                            <div class="progress-bar bg-success" id="progress-new" style="width: @(stats.TotalLeads > 0 ? (stats.NewLeads * 100.0 / stats.TotalLeads) : 0)%"></div>
                            <div class="progress-bar bg-info" id="progress-contacted" style="width: @(stats.TotalLeads > 0 ? (stats.ContactedLeads * 100.0 / stats.TotalLeads) : 0)%"></div>
                            <div class="progress-bar bg-secondary" id="progress-closed" style="width: @(stats.TotalLeads > 0 ? (stats.ClosedLeads * 100.0 / stats.TotalLeads) : 0)%"></div>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-success"><i class="bi bi-circle-fill"></i> Mới: <span id="panel-newLeads">@stats.NewLeads</span></span>
                            <span class="text-info"><i class="bi bi-circle-fill"></i> Đã liên hệ: <span id="panel-contactedLeads">@stats.ContactedLeads</span></span>
                            <span class="text-secondary"><i class="bi bi-circle-fill"></i> Đã chốt: <span id="panel-closedLeads">@stats.ClosedLeads</span></span>
                        </div>
                    </div>
                    <div class="revenue-item">
                        <p class="text-muted mb-1">Tỷ lệ chuyển đổi</p>
                        <h4 class="text-success mb-0" id="panel-conversionRate">@stats.ConversionRate%</h4>
                        <small class="text-muted">
                            <span id="panel-closedCount">@stats.ClosedLeads</span> trên <span id="panel-totalCount">@stats.TotalLeads</span> khách hàng
                        </small>
                    </div>
                    @if (stats.LastLeadReceivedAt.HasValue)
                    {
                        <div class="mt-3 pt-3 border-top">
                            <small class="text-muted">
                                <i class="bi bi-clock"></i> Last lead received: 
                                @{
                                    var timeSpan = DateTime.UtcNow - stats.LastLeadReceivedAt.Value;
                                    if (timeSpan.TotalMinutes < 60)
                                    {
                                        <span>@Math.Floor(timeSpan.TotalMinutes) minutes ago</span>
                                    }
                                    else if (timeSpan.TotalHours < 24)
                                    {
                                        <span>@Math.Floor(timeSpan.TotalHours) hours ago</span>
                                    }
                                    else
                                    {
                                        <span>@Math.Floor(timeSpan.TotalDays) days ago</span>
                                    }
                                }
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top Performing Listings -->
    <div class="row g-4">
        <div class="col-12">
            <div class="dashboard-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-star me-2"></i>Top Performing Listings
                    </h5>
                    <a asp-page="/Lister/Listings" class="btn btn-sm btn-outline-primary">View All Listings</a>
                </div>
                <div class="card-body">
                    @if (stats.TopPerformingListings.Any())
                    {
                        <div class="top-listings">
                            @for (int i = 0; i < stats.TopPerformingListings.Count; i++)
                            {
                                var listing = stats.TopPerformingListings[i];
                                <div class="top-listing-item">
                                    <div class="listing-rank">@(i + 1)</div>
                                    <div class="listing-info">
                                        <h6 class="listing-title">@listing.Title</h6>
                                        <p class="listing-stats text-muted mb-0">
                                            <i class="bi bi-eye"></i> @listing.ViewCount views  
                                            <i class="bi bi-people"></i> @listing.LeadCount leads
                                        </p>
                                    </div>
                                    <a asp-page="/Lister/Details" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3">No published listings yet</p>
                            <a asp-page="/Lister/Create" class="btn btn-primary">Create Your First Listing</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container for Real-Time Notifications -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index: 1080;"></div>

<style>
    .dashboard-container {
        max-width: 1400px;
    }

    .page-header {
        padding-bottom: 1rem;
        border-bottom: 1px solid #dee2e6;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .page-subtitle {
        font-size: 1rem;
        margin-bottom: 0;
    }

    /* Stat Cards */
    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        flex-shrink: 0;
    }

    .stat-card-primary .stat-icon {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .stat-card-success .stat-icon {
        background: linear-gradient(135deg, #56ab2f 0%, #a8e063 100%);
        color: white;
    }

    .stat-card-warning .stat-icon {
        background: linear-gradient(135deg, #f2994a 0%, #f2c94c 100%);
        color: white;
    }

    .stat-card-info .stat-icon {
        background: linear-gradient(135deg, #2193b0 0%, #6dd5ed 100%);
        color: white;
    }

    .stat-card-secondary .stat-icon {
        background: linear-gradient(135deg, #8e9eab 0%, #eef2f3 100%);
        color: #2c3e50;
    }

    .stat-card-danger .stat-icon {
        background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
        color: white;
    }

    .stat-card-boost .stat-icon {
        background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
        color: white;
    }

    .stat-card-conversion .stat-icon {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
    }

    .stat-content {
        flex-grow: 1;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #2c3e50;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #7f8c8d;
        margin-bottom: 0;
    }

    /* Dashboard Cards */
    .dashboard-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
        height: 100%;
    }

    .dashboard-card .card-header {
        padding: 1.5rem;
        border-bottom: 1px solid #f0f0f0;
        background: white;
    }

    .dashboard-card .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c3e50;
    }

    .dashboard-card .card-body {
        padding: 1.5rem;
    }

    /* Top Listings */
    .top-listings {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .top-listing-item {
        display: flex;
        gap: 1rem;
        align-items: center;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .top-listing-item:hover {
        background: #e9ecef;
        transform: translateX(5px);
    }

    .listing-rank {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .listing-info {
        flex-grow: 1;
    }

    .listing-title {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 0.25rem;
        color: #2c3e50;
    }

    .listing-stats {
        font-size: 0.85rem;
        margin-bottom: 0;
    }

    .listing-stats i {
        margin-right: 0.25rem;
    }

    /* Revenue */
    .revenue-item {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 8px;
    }

    /* Stat update animation */
    .stat-updated {
        animation: statPulse 0.6s ease-in-out;
    }

    @@keyframes statPulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); color: #0d6efd; }
        100% { transform: scale(1); }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // Current user ID for SignalR group
        const currentUserId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
        let performanceChart = null;

        document.addEventListener('DOMContentLoaded', function() {
            // Prepare chart data
            const chartLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stats.LeadsChartData.Select(d => d.Label)));
            const leadsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stats.LeadsChartData.Select(d => d.Value)));
            const conversionData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stats.ConversionChartData.Select(d => d.Value)));
            const viewsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stats.ViewsChartData.Select(d => d.Value)));

            // Create performance chart
            const ctx = document.getElementById('performanceChart');
            performanceChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartLabels,
                    datasets: [
                        {
                            label: 'Leads',
                            data: leadsData,
                            borderColor: '#2193b0',
                            backgroundColor: 'rgba(33, 147, 176, 0.1)',
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y'
                        },
                        {
                            label: 'Conversion Rate (%)',
                            data: conversionData,
                            borderColor: '#56ab2f',
                            backgroundColor: 'rgba(86, 171, 47, 0.1)',
                            tension: 0.4,
                            fill: true,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                usePointStyle: true,
                                padding: 15,
                                font: {
                                    size: 12,
                                    family: "'Inter', sans-serif"
                                }
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            padding: 12,
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 13
                            },
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        if (context.dataset.label === 'Conversion Rate (%)') {
                                            label += context.parsed.y + '%';
                                        } else {
                                            label += context.parsed.y;
                                        }
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Leads',
                                font: {
                                    size: 12,
                                    weight: 'bold'
                                }
                            },
                            ticks: {
                                precision: 0
                            },
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            title: {
                                display: true,
                                text: 'Conversion Rate (%)',
                                font: {
                                    size: 12,
                                    weight: 'bold'
                                }
                            },
                            ticks: {
                                callback: function(value) {
                                    return value + '%';
                                }
                            },
                            grid: {
                                drawOnChartArea: false,
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });

            // === SignalR Connection ===
            initSignalR();
        });

        // Animate stat update
        function animateStat(elementId, newValue) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.textContent = newValue;
            el.classList.remove('stat-updated');
            void el.offsetWidth; // trigger reflow
            el.classList.add('stat-updated');
        }

        // Show toast notification
        function showToast(title, message, type) {
            const container = document.getElementById('toastContainer');
            const icons = {
                'success': 'bi-check-circle-fill text-success',
                'info': 'bi-info-circle-fill text-primary',
                'warning': 'bi-exclamation-triangle-fill text-warning',
                'danger': 'bi-x-circle-fill text-danger'
            };
            const iconClass = icons[type] || icons['info'];
            const toastId = 'toast-' + Date.now();
            const html = `
                <div id="${toastId}" class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header">
                        <i class="bi ${iconClass} me-2"></i>
                        <strong class="me-auto">${title}</strong>
                        <small>Just now</small>
                        <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
                    </div>
                    <div class="toast-body">${message}</div>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
            const toastEl = document.getElementById(toastId);
            const bsToast = new bootstrap.Toast(toastEl, { delay: 5000 });
            bsToast.show();
            toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
        }

        // Fetch fresh stats from server and update all dashboard elements
        async function refreshDashboardStats() {
            try {
                const response = await fetch('/Lister/Dashboard?handler=Stats');
                const result = await response.json();
                if (!result.success || !result.data) return;

                const d = result.data;

                // Update stat cards
                animateStat('stat-totalListings', d.totalListings);
                animateStat('stat-activeListings', d.activeListings);
                animateStat('stat-pendingReview', d.pendingReview);
                animateStat('stat-totalLeads', d.totalLeads);
                animateStat('stat-draftListings', d.draftListings);
                animateStat('stat-expiredListings', d.expiredListings);
                animateStat('stat-boostedListings', d.boostedListings);
                animateStat('stat-conversionRate', d.conversionRate + '%');
                animateStat('stat-closedLeads', d.closedLeads);

                const psr = document.getElementById('stat-publishSuccessRate');
                if (psr) psr.textContent = d.publishSuccessRate;

                const nlb = document.getElementById('stat-newLeadsBadge');
                if (nlb) nlb.textContent = d.newLeads + ' New';

                const ess = document.getElementById('stat-expiringListingsSoon');
                if (ess) ess.textContent = d.expiringListingsSoon;

                // Update Lead Statistics panel
                const ptl = document.getElementById('panel-totalLeads');
                if (ptl) ptl.textContent = d.totalLeads;

                const pnl = document.getElementById('panel-newLeads');
                if (pnl) pnl.textContent = d.newLeads;

                const pcl = document.getElementById('panel-contactedLeads');
                if (pcl) pcl.textContent = d.contactedLeads;

                const pcls = document.getElementById('panel-closedLeads');
                if (pcls) pcls.textContent = d.closedLeads;

                const pcr = document.getElementById('panel-conversionRate');
                if (pcr) pcr.textContent = d.conversionRate + '%';

                const pcc = document.getElementById('panel-closedCount');
                if (pcc) pcc.textContent = d.closedLeads;

                const ptc = document.getElementById('panel-totalCount');
                if (ptc) ptc.textContent = d.totalLeads;

                // Update progress bars
                if (d.totalLeads > 0) {
                    const pn = document.getElementById('progress-new');
                    if (pn) pn.style.width = (d.newLeads * 100.0 / d.totalLeads) + '%';
                    const pc = document.getElementById('progress-contacted');
                    if (pc) pc.style.width = (d.contactedLeads * 100.0 / d.totalLeads) + '%';
                    const pcl2 = document.getElementById('progress-closed');
                    if (pcl2) pcl2.style.width = (d.closedLeads * 100.0 / d.totalLeads) + '%';
                }

                // Update chart data
                if (performanceChart && d.leadsChartData && d.conversionChartData) {
                    performanceChart.data.labels = d.leadsChartData.map(p => p.label);
                    performanceChart.data.datasets[0].data = d.leadsChartData.map(p => p.value);
                    performanceChart.data.datasets[1].data = d.conversionChartData.map(p => p.value);
                    performanceChart.update('none');
                }
            } catch (error) {
                console.error('Error refreshing dashboard stats:', error);
            }
        }

        // Initialize SignalR connection
        function initSignalR() {
            const badge = document.getElementById('connection-badge');

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/dashboard')
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .build();

            connection.on('ReceiveDashboardUpdate', function(eventType, data) {
                console.log('Dashboard update received:', eventType, data);

                if (eventType === 'NewLead') {
                    showToast(
                        'New Lead!',
                        `<strong>${data.seekerName}</strong> is interested in <em>${data.listingTitle}</em>`,
                        'success'
                    );
                } else if (eventType === 'LeadStatusUpdated') {
                    showToast(
                        'Lead Updated',
                        `Lead status changed to <strong>${data.newStatus}</strong>`,
                        'info'
                    );
                }

                // Refresh all dashboard metrics from server
                refreshDashboardStats();
            });

            connection.onreconnecting(function() {
                badge.className = 'badge bg-warning';
                badge.innerHTML = '<i class="bi bi-arrow-repeat"></i> Reconnecting...';
            });

            connection.onreconnected(function() {
                badge.className = 'badge bg-success';
                badge.innerHTML = '<i class="bi bi-wifi"></i> Live';
                // Re-join group after reconnect
                if (currentUserId) {
                    connection.invoke('JoinListerGroup', currentUserId).catch(console.error);
                }
            });

            connection.onclose(function() {
                badge.className = 'badge bg-danger';
                badge.innerHTML = '<i class="bi bi-wifi-off"></i> Disconnected';
            });

            connection.start()
                .then(function() {
                    badge.className = 'badge bg-success';
                    badge.innerHTML = '<i class="bi bi-wifi"></i> Live';
                    // Join the lister's group to receive targeted updates
                    if (currentUserId) {
                        connection.invoke('JoinListerGroup', currentUserId).catch(console.error);
                    }
                })
                .catch(function(err) {
                    console.error('SignalR connection error:', err);
                    badge.className = 'badge bg-danger';
                    badge.innerHTML = '<i class="bi bi-wifi-off"></i> Offline';
                });
        }
    </script>
}
